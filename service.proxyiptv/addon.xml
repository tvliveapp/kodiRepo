<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.proxyiptv" name="Proxy IPTV" version="1.0.0" provider-name="IPTV Local">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
        <import addon="script.module.beautifulsoup4" version="4.9.3"/>
    </requires>
    
    <!-- Servicio que arranca automáticamente con Kodi -->
    <extension point="xbmc.service" library="main.py" start="startup"/>
    
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Proxy para Listas IPTV</summary>
        <description lang="es">Servicio local en segundo plano que actúa como proxy para gestionar transmisiones IPTV.</description>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
    </extension>
</addon>
